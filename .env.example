# Environment Variables for CorfuHub Apps
# Copy this file to .env and fill in your actual values
# VS Code launch.json will read these variables

# ========================================
# STAGING ENVIRONMENT
# ========================================
STAGING_SUPABASE_URL=https://your-staging-project.supabase.co
STAGING_SUPABASE_ANON_KEY=your-staging-anon-key-here

# ========================================
# PRODUCTION ENVIRONMENT
# ========================================
PROD_SUPABASE_URL=https://your-production-project.supabase.co
PROD_SUPABASE_ANON_KEY=your-production-anon-key-here

# ========================================
# NOTES
# ========================================
# - LOCAL uses hardcoded localhost:54331 (Supabase CLI default)
# - LOCAL anon key is the standard Supabase local development JWT
# - NEVER commit production keys to version control
# - Add .env to .gitignore (already done if using standard .gitignore)
